# Copy this file to .env and fill in your values
# NEVER commit .env to git!

# Your wallet private key (for deployment)
# Get this from MetaMask: Account Details > Export Private Key
PRIVATE_KEY=0x9c7810011E8C1e0b4AE22624971E7AF590a2A4Ac

# Base Sepolia RPC URL (optional, defaults to public RPC)
BASE_SEPOLIA_RPC=https://sepolia.base.org

# BaseScan API key (optional, for contract verification)
# Get from: https://basescan.org/myapikey
BASESCAN_API_KEY=your_basescan_api_key_here
